# ── Spotify App ──────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add  https://your-app.vercel.app/api/auth/callback  as a Redirect URI
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# ── Host access ───────────────────────────────────────────────────────────────
# Password to protect the /host dashboard (choose anything)
HOST_PASSWORD=your_secret_password_here

# ── App URL ───────────────────────────────────────────────────────────────────
# Your Vercel deployment URL — no trailing slash
APP_URL=https://your-app.vercel.app

# ── Vercel KV (Upstash Redis) ─────────────────────────────────────────────────
# These are set automatically when you add a KV store in the Vercel dashboard.
# Storage > Create Database > KV > link to this project.
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=your_kv_token_here

# NOTE: SPOTIFY_REFRESH_TOKEN and SPOTIFY_PLAYLIST_ID are no longer used.
# The refresh token is saved to KV automatically during the /host OAuth flow.
# Playlists are created per-event from the host dashboard.
